# Polymarket API
POLYMARKET_PRIVATE_KEY=0x...

# Moonshot AI (Kimi) - Replaces Claude
MOONSHOT_API_KEY=sk-...

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_CHAT_ID=123456789

# Trading Settings
LIVE_TRADING=false     # set to "true" to place real orders — default is dry-run
BANKROLL_USD=1000
MAX_POSITION_SIZE=200
MAX_POSITIONS=3

# Database
# Local dev: leave DATABASE_URL unset → SQLite at DATABASE_PATH
# Railway/Supabase: set DATABASE_URL → PostgreSQL (SQLite is ignored)
DATABASE_PATH=./data/polymarket.db
DATABASE_URL=postgresql://postgres:[password]@db.dftkwvdhwkbtjxutgqzy.supabase.co:5432/postgres

# Polygon RPC (for Chainlink oracle reads)
POLYGON_RPC_URL=https://polygon.drpc.org

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.polymarket.server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jayzhuang/Desktop/Personal Agent projects/Polymarket_Tailend Trading/.venv/bin/python3</string>
